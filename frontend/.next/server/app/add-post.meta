{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/add-post/layout,_N_T_/add-post/page,_N_T_/add-post"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/add-post/__PAGE__",
    "/add-post",
    "/_index",
    "/_head"
  ]
}